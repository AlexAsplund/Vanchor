[connection]
id=vanchor-setup
uuid=b1e0c1a4-0000-4000-8000-76616e63686f
type=wifi
interface-name=wlan0
autoconnect=true
autoconnect-priority=-10

[wifi]
mode=ap
ssid=vanchor-setup
band=bg

[wifi-security]
key-mgmt=wpa-psk
psk=vanchor-boat

[ipv4]
method=shared
address1=10.42.0.1/24

[ipv6]
method=disabled
