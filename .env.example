# Vanchor-NG environment configuration.
#
# Copy this file to `.env` (which is git-ignored) and uncomment the values you
# want to override. Every variable is OPTIONAL: an unset variable keeps the
# value from your YAML/JSON config file, or the built-in default if no file is
# loaded. A real environment variable always wins over a value in `.env`.
#
# These override the corresponding config fields after the config file is read,
# so the environment is the highest-priority source. There are no secrets here
# -- only bind hosts/ports, device paths, and public OSM endpoints.

# ----------------------------------------------------------------------------
# Server (web UI / HTTP bind address)
# ----------------------------------------------------------------------------
# VANCHOR_HOST=127.0.0.1        # interface the web UI binds to (0.0.0.0 = all)
# VANCHOR_PORT=8000             # web UI / HTTP port

# ----------------------------------------------------------------------------
# Data
# ----------------------------------------------------------------------------
# VANCHOR_DATA_DIR=vanchor_data # where the depth map, trips, devices.json live

# ----------------------------------------------------------------------------
# Simulation
# ----------------------------------------------------------------------------
# VANCHOR_MODEL=fossen          # physics model: "fossen" (3-DOF) or "simple"
# VANCHOR_TIME_SCALE=1.0        # sim speed multiplier (1.0 = real time)
# VANCHOR_PHYSICS_HZ=20.0       # physics integration rate (Hz)
# VANCHOR_SIM_START_LAT=59.66275 # boat's starting latitude
# VANCHOR_SIM_START_LON=13.32247 # boat's starting longitude

# ----------------------------------------------------------------------------
# Sensors & hardware (real serial devices; off by default = full simulation)
# ----------------------------------------------------------------------------
# VANCHOR_HARDWARE=false        # master switch: true = use real serial devices
# VANCHOR_GPS_PORT=/dev/ttyUSB0     # serial port for the GPS receiver
# VANCHOR_COMPASS_PORT=/dev/ttyUSB1 # serial port for the compass
# VANCHOR_MOTOR_PORT=/dev/ttyUSB2   # serial port for the steering/motor servo
# VANCHOR_BAUDRATE=4800         # serial baud rate for all devices
# VANCHOR_GPS_SOURCE=            # per-device override: sim | serial | nmea
# VANCHOR_COMPASS_SOURCE=        # per-device override: sim | serial | nmea
# VANCHOR_DEPTH_SOURCE=          # per-device override: sim | nmea
# VANCHOR_MOTOR_SOURCE=          # per-device override: sim | serial | both

# ----------------------------------------------------------------------------
# NMEA bridge (NMEA-0183 over TCP, e.g. for OpenCPN / phone nav apps)
# ----------------------------------------------------------------------------
# VANCHOR_NMEA_TCP=false        # enable the NMEA-over-TCP server
# VANCHOR_NMEA_TCP_HOST=0.0.0.0 # interface the NMEA server binds to
# VANCHOR_NMEA_TCP_PORT=10110   # NMEA-over-TCP port (de-facto standard: 10110)

# ----------------------------------------------------------------------------
# Routing (OpenStreetMap Overpass API for water/land geometry)
# ----------------------------------------------------------------------------
# VANCHOR_OVERPASS_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter  # comma-separated, tried in order
# VANCHOR_USER_AGENT=vanchor-ng/2.0 (+https://github.com/your-org/vanchor-ng)  # HTTP User-Agent for Overpass requests

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
# VANCHOR_ENV_FILE=.env         # path to this env file (read before the above)
